# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ─────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=clawx-cloud-dev-secret-change-me

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory where store.json and per-workspace configs are kept
DATA_DIR=./data

# ── OpenClaw Gateway ─────────────────────────────────────────────────────────
# Full path to the openclaw binary (defaults to "openclaw" in $PATH)
OPENCLAW_BIN=openclaw

# Arguments template for "openclaw serve" — {port} is replaced at runtime
OPENCLAW_SERVE_ARGS=serve --port {port}
