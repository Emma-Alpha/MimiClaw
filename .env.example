# ClawX Environment Variables

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_PORT=18789

# Development Configuration
VITE_DEV_SERVER_PORT=5173

# Cloud Backend Configuration
PORT=3000
JWT_SECRET=clawx-cloud-dev-secret-change-me
DATA_DIR=./backend/data
OPENCLAW_BIN=openclaw
OPENCLAW_SERVE_ARGS=serve --port {port}

# Optional: HTTPS JSON to drive forced update modal (minimumVersion / forceUpdateModalWhenAvailable)
VITE_UPDATE_POLICY_URL=https://cobot-1254397474.cos.ap-guangzhou.myqcloud.com/jizhi/update-policy.json

# Renderer-side Xiaojiu defaults (optional; override only when needed)
VITE_XIAOJIU_AUTH_URL=https://im.4399om.com/oauth2/authorization
VITE_XIAOJIU_CLIENT_ID=1816386499001556992
VITE_XIAOJIU_CALLBACK_URL=https://local-jizhiai-main.gz4399.com/om/desktop-callback
VITE_XIAOJIU_EXCHANGE_PATH=/api/main/v1/gateway/om_login

# Release Configuration (CI/CD)
# Apple Developer Credentials
APPLE_ID=your@email.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# Code Signing Certificate
CSC_LINK=path/to/certificate.p12
