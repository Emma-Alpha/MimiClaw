# MimiClaw Environment Variables
#
# Recommended layout:
# - `.env.development` for local development
# - `.env.test` for test / staging packages (`vite build --mode test`)
# - `.env.production` for release packages
# - `*.local` files for machine-local overrides that should not be committed
#
# Backend (`backend/src/load-env.ts`) resolves:
# backend/.env -> backend/.env.local -> backend/.env.<env> -> backend/.env.<env>.local
# -> .env -> .env.local -> .env.<env> -> .env.<env>.local
# where <env> comes from APP_ENV or NODE_ENV.

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_PORT=18789

# Renderer / Desktop configuration
# Development defaults: local dev backend + local remote chat page
# Production defaults: api.jizhiai.gz4399.com + jizhiai.gz4399.com
VITE_APP_ENV=development
VITE_CLOUD_API_BASE_URL=http://local-jizhiai-main.gz4399.com
VITE_JIZHI_API_BASE_URL=
VITE_JIZHI_APP_BASE_URL=https://dev-jizhi.gz4399.com
VITE_REMOTE_JIZHI_CHAT_URL=https://local-jizhiai-main.gz4399.com/

# Development Configuration
VITE_DEV_SERVER_PORT=5173

# Cloud Backend Configuration
APP_ENV=development
PORT=3000
JWT_SECRET=mimiclaw-cloud-dev-secret-change-me
DATA_DIR=./backend/data
OPENCLAW_BIN=openclaw
OPENCLAW_SERVE_ARGS=serve --port {port}

# Optional: HTTPS JSON to drive forced update modal (minimumVersion / forceUpdateModalWhenAvailable)
VITE_UPDATE_POLICY_URL=https://cobot-1254397474.cos.ap-guangzhou.myqcloud.com/jizhi/update-policy.json

# Renderer-side Xiaojiu defaults (optional; override only when needed)
# By default the desktop app now uses:
#   <VITE_CLOUD_API_BASE_URL>/api/auth/xiaojiu/browser-callback
# as the OAuth callback, so packaged builds no longer fall back to the local
# `local-jizhiai-main` callback page unless you explicitly configure it.
VITE_XIAOJIU_AUTH_URL=https://im.4399om.com/oauth2/authorization
VITE_XIAOJIU_CLIENT_ID=1816386499001556992
VITE_XIAOJIU_EXCHANGE_PATH=/api/main/v1/gateway/om_login

# Release Configuration (CI/CD)
# Apple Developer Credentials
APPLE_ID=your@email.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# Code Signing Certificate
CSC_LINK=path/to/certificate.p12
CSC_KEY_PASSWORD=certificate_password

# GitHub Token for releases
GH_TOKEN=github_personal_access_token
