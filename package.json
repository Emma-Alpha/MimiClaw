{
    "name": "jizhi",
    "version": "0.2.12-beta.16",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@discordjs/opus",
            "@whiskeysockets/baileys",
            "electron",
            "esbuild",
            "koffi",
            "node-llama-cpp",
            "protobufjs",
            "sharp"
        ],
        "overrides": {
            "isbinaryfile": "^5.0.0",
            "https-proxy-agent": "7.0.6"
        }
    },
    "description": "极智 - AI 智能助手",
    "repository": {
        "type": "git",
        "url": "https://github.com/Emma-Alpha/MimiClaw.git"
    },
    "main": "dist-electron/main/index.js",
    "author": "极智团队",
    "license": "MIT",
    "private": true,
    "scripts": {
        "init": "pnpm install && pnpm run uv:download",
        "dev": "vite",
        "build": "vite build && electron-builder",
        "build:vite": "vite build",
        "build:vite:test": "vite build --mode test",
        "build:vite:prod": "vite build --mode production",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:ci": "vitest run --reporter=dot --silent=passed-only",
        "comms:replay": "node scripts/comms/replay.mjs",
        "comms:baseline": "node scripts/comms/baseline.mjs",
        "comms:compare": "node scripts/comms/compare.mjs",
        "uv:download": "zx scripts/download-bundled-uv.mjs",
        "uv:download:mac": "zx scripts/download-bundled-uv.mjs --platform=mac",
        "uv:download:win": "zx scripts/download-bundled-uv.mjs --platform=win",
        "uv:download:linux": "zx scripts/download-bundled-uv.mjs --platform=linux",
        "uv:download:all": "zx scripts/download-bundled-uv.mjs --all",
        "node:download:win": "zx scripts/download-bundled-node.mjs --platform=win",
        "prep:win-binaries": "pnpm run uv:download:win && pnpm run node:download:win",
        "icons": "zx scripts/generate-icons.mjs",
        "package": "vite build",
        "package:test": "vite build --mode test",
        "package:prod": "vite build --mode production",
        "package:prep:ci": "zx scripts/package-prep-ci.mjs",
        "package:mac": "pnpm run package && electron-builder --mac --publish never",
        "package:mac:test": "pnpm run package:test && electron-builder --mac --publish never",
        "package:mac:prod": "pnpm run package:prod && electron-builder --mac --publish never",
        "package:mac:ci": "pnpm run package:prep:ci && electron-builder --mac --publish never",
        "package:mac:local": "pnpm run package && electron-builder --mac --publish never",
        "package:win": "pnpm run prep:win-binaries && pnpm run package && electron-builder --win --publish never",
        "package:win:test": "pnpm run prep:win-binaries && pnpm run package:test && electron-builder --win --publish never",
        "package:win:prod": "pnpm run prep:win-binaries && pnpm run package:prod && electron-builder --win --publish never",
        "package:win:ci": "pnpm run prep:win-binaries && pnpm run package:prep:ci && electron-builder --win --publish never",
        "package:linux": "pnpm run package && electron-builder --linux --publish never",
        "package:linux:test": "pnpm run package:test && electron-builder --linux --publish never",
        "package:linux:prod": "pnpm run package:prod && electron-builder --linux --publish never",
        "package:linux:ci": "pnpm run package:prep:ci && electron-builder --linux --publish never",
        "package:cloud": "zx scripts/package-cloud.mjs --mode=production",
        "package:cloud:test": "zx scripts/package-cloud.mjs --mode=test",
        "package:cloud:prod": "zx scripts/package-cloud.mjs --mode=production",
        "package:mac:cloud": "zx scripts/package-cloud.mjs --mode=production --platform=mac",
        "package:mac:cloud:test": "zx scripts/package-cloud.mjs --mode=test --platform=mac",
        "package:mac:cloud:prod": "zx scripts/package-cloud.mjs --mode=production --platform=mac",
        "package:win:cloud": "zx scripts/package-cloud.mjs --mode=production --platform=win",
        "package:win:cloud:test": "zx scripts/package-cloud.mjs --mode=test --platform=win",
        "package:win:cloud:prod": "zx scripts/package-cloud.mjs --mode=production --platform=win",
        "package:linux:cloud": "zx scripts/package-cloud.mjs --mode=production --platform=linux",
        "package:linux:cloud:test": "zx scripts/package-cloud.mjs --mode=test --platform=linux",
        "package:linux:cloud:prod": "zx scripts/package-cloud.mjs --mode=production --platform=linux",
        "release": "pnpm run uv:download && pnpm run package && electron-builder --publish always",
        "version:patch": "node scripts/npm-version.mjs patch",
        "version:minor": "node scripts/npm-version.mjs minor",
        "version:major": "node scripts/npm-version.mjs major",
        "postversion": "git push -u origin HEAD && git push --tags",
        "tag:push": "node scripts/tag-push.mjs",
        "tag:push:force": "node scripts/tag-push.mjs --force"
    },
    "dependencies": {
        "@4399ywkf/theme-system": "^1.0.13",
        "@lobehub/editor": "^4.5.0",
        "@lobehub/fluent-emoji": "^4.1.0",
        "@lobehub/icons": "^5.2.0",
        "@lobehub/ui": "^5.6.1",
        "antd": "^6.3.4",
        "antd-style": "^4.1.0",
        "clawhub": "^0.5.0",
        "electron-store": "^11.0.2",
        "electron-updater": "^6.8.3",
        "motion": "^12.38.0",
        "ms": "^2.1.3",
        "node-machine-id": "^1.1.12",
        "posthog-node": "^5.28.0",
        "react-layout-kit": "^2.0.1",
        "semver": "^7.7.4",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/semver": "^7.7.1",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "@vitejs/plugin-react": "^5.1.4",
        "autoprefixer": "^10.4.24",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1",
        "eslint": "^10.0.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.0",
        "framer-motion": "^12.34.2",
        "globals": "^17.3.0",
        "i18next": "^25.8.11",
        "jsdom": "^28.1.0",
        "lucide-react": "^0.563.0",
        "png2icons": "^2.0.1",
        "postcss": "^8.5.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^16.5.4",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.13.0",
        "remark-gfm": "^4.0.1",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^3.4.19",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5.9.3",
        "use-stick-to-bottom": "^1.1.3",
        "vite": "^7.3.1",
        "vite-plugin-electron": "^0.29.0",
        "vite-plugin-electron-renderer": "^0.14.6",
        "vitest": "^4.0.18",
        "zustand": "^5.0.11",
        "zx": "^8.8.5"
    },
    "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
